      <ReportItem port="0" svc_name="general" protocol="icmp" severity="1" pluginID="10114" pluginName="ICMP Timestamp Request Remote Date Disclosure" pluginFamily="General">
        <cvss_base_score>2.6</cvss_base_score>
        <cvss_vector>AV:N/AC:H/Au:N/C:P/I:N/A:N</cvss_vector>
        <description>The remote host answers to an ICMP timestamp request. This allows an attacker to know the date set on the targeted machine, which may assist in defeating time-based authentication protocols.</description>
        <fname>icmp_timestamp.nasl</fname>
        <plugin_output>This host returns non-standard timestamps (high bit is set).</plugin_output>
        <risk_factor>Low</risk_factor>
        <solution>Filter out the ICMP timestamp requests (13) and outgoing ICMP timestamp replies (14).</solution>
        <synopsis>It is possible to determine the exact time set on the remote host.</synopsis>
      </ReportItem>

