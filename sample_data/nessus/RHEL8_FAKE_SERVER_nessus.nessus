      <ReportItem port="22" svc_name="ssh" protocol="tcp" severity="3" pluginID="153953" pluginName="SSH Server CBC Mode Ciphers Enabled" pluginFamily="Misc.">
        <agent>all</agent>
        <cvss3_base_score>7.5</cvss3_base_score>
        <cvss3_vector>CVSS:3.0/AV:N/AC:L/PR:N/UI:N/S:U/C:H/I:N/A:N</cvss3_vector>
        <cvss_base_score>6.4</cvss_base_score>
        <cvss_vector>AV:N/AC:L/Au:N/C:P/I:P/A:N</cvss_vector>
        <description>The SSH server is configured to support Cipher Block Chaining (CBC) encryption. This may allow an attacker to recover the plaintext message from the ciphertext.</description>
        <fname>ssh_cbc_supported_ciphers.nasl</fname>
        <plugin_output>The following CBC algorithms are supported :
  aes128-cbc
  aes256-cbc
  3des-cbc</plugin_output>
        <risk_factor>High</risk_factor>
        <solution>Disable CBC mode cipher encryption and enable CTR or GCM cipher mode encryption.</solution>
        <synopsis>The SSH server is configured to use Cipher Block Chaining encryption.</synopsis>
        <vuln_publication_date>2008/11/01</vuln_publication_date>
      </ReportItem>

